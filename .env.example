# ═══════════════════════════════════════════════════
#   SYNTHRON — Environment Configuration
#   Copy to .env and fill in your keys
# ═══════════════════════════════════════════════════

# ─── LLM Provider API Keys ───────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GITHUB_MODELS_TOKEN=your_github_token_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── Optional: Paid Providers ─────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Memory ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_URL=sqlite+aiosqlite:///./data/synthron.db

# ─── Pinecone (optional cloud vector DB) ──────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=synthron

# ─── Dashboard ────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_SECRET=change_this_secret_key

# ─── Ollama (local, offline) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ─── Search Tools ─────────────────────────────────
SERPER_API_KEY=
# DuckDuckGo works without a key

# ─── Observability (optional) ─────────────────────
WANDB_API_KEY=
SYNTHRON_LOG_LEVEL=INFO
SYNTHRON_ENV=development
